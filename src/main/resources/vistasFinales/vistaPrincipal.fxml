<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720.0" prefWidth="1020.0" style="-fx-background-color: #F8F5F0;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.loginController">

    <center>
        <HBox alignment="CENTER" fillHeight="true" maxHeight="620.0" maxWidth="980.0" style="-fx-background-color: white;                      -fx-background-radius: 20;                      -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 20, 0, 0, 8);">
            <BorderPane.margin>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </BorderPane.margin>

            <!-- Panel izquierdo: formulario -->
            <VBox alignment="CENTER_LEFT" maxWidth="480.0" minWidth="480.0" spacing="20.0" style="-fx-background-color: white;                          -fx-background-radius: 20 0 0 20;                          -fx-padding: 60 50 60 50;">

                <VBox spacing="6.0">
                    <Label style="-fx-text-fill: #48295a; -fx-font-size: 30; -fx-font-weight: bold;" text="Inicio de sesión">
                  <font>
                     <Font size="25.0" />
                  </font></Label>
                    <Label style="-fx-text-fill: #9c7db5; -fx-font-size: 15;" text="Coloca tu usuario y contraseña" />
                </VBox>

                <VBox spacing="18.0" style="-fx-background-color: #EDE5F5;                              -fx-background-radius: 16;                              -fx-padding: 28 26 28 26;">

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #48295a; -fx-font-weight: bold; -fx-font-size: 13;" text="USUARIO" />
                        <TextField fx:id="txtUsuario" onAction="#iniciarSesion" prefHeight="46.0" promptText="tu.usuario" style="-fx-background-color: white;                                           -fx-text-fill: #2d1a38;                                           -fx-prompt-text-fill: #c9b8db;                                           -fx-border-color: #c9b8db;                                           -fx-border-radius: 10;                                           -fx-background-radius: 10;                                           -fx-font-size: 15;" />
                    </VBox>

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #48295a; -fx-font-weight: bold; -fx-font-size: 13;" text="CONTRASEÑA" />
                        <PasswordField fx:id="txtPassword" onAction="#iniciarSesion" prefHeight="46.0" promptText="••••••••" style="-fx-background-color: white;                                               -fx-text-fill: #2d1a38;                                               -fx-prompt-text-fill: #c9b8db;                                               -fx-border-color: #c9b8db;                                               -fx-border-radius: 10;                                               -fx-background-radius: 10;                                               -fx-font-size: 15;" />
                    </VBox>
                </VBox>

                <Button defaultButton="true" maxWidth="Infinity" onAction="#iniciarSesion" prefHeight="50.0" style="-fx-background-color: #48295a;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-font-size: 16;                                -fx-background-radius: 12;                                -fx-cursor: hand;" text="INGRESAR" />
            </VBox>


            <StackPane maxWidth="500.0" minWidth="500.0" style="-fx-background-color: #7B4F96;                               -fx-background-radius: 0 20 20 0;">
                <children>
                    <VBox alignment="CENTER" spacing="14.0">
                        <ImageView fitHeight="500.0" fitWidth="800.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../com/example/chocolateria/logo.png" />
                            </image>
                        </ImageView>
                        <VBox alignment="CENTER" spacing="4.0">
                            <Label style="-fx-text-fill: #f0e6fa; -fx-font-size: 14; -fx-font-weight: bold;" />
                            <Label style="-fx-text-fill: #d1b8e8; -fx-font-size: 12;" />
                        </VBox>
                    </VBox>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
