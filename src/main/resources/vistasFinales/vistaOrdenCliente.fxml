                                <Label style="-fx-font-weight:bold; -fx-font-size:12px; -fx-text-fill:#3B1A5C;" text="Precio" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                <TextField fx:id="txtPrecio" editable="false" prefWidth="110" GridPane.columnIndex="1" GridPane.rowIndex="3"
