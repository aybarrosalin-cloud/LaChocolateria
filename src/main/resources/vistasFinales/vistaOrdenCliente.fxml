                            </VBox>
                            <VBox minHeight="60" spacing="5" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:13px; -fx-text-fill:#3B1A5C;" text="Cliente" />
