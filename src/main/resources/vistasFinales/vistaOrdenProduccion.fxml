<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720.0" prefWidth="1020.0" style="-fx-background-color: #f3eaf8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.ordenProduccionController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="190.0" spacing="6" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="10" right="10" top="24" />
            </padding>

            <StackPane maxHeight="80" maxWidth="80" minHeight="80" minWidth="80">
                <ImageView fx:id="imgFotoPerfil" fitHeight="100.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../com/example/chocolateria/perfilr.png" />
                    </image>
                </ImageView>
            </StackPane>

            <Label alignment="CENTER" prefHeight="20.0" prefWidth="91.0" style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Rosalin Aybar" wrapText="true">
                <font><Font name="Courier New" size="10" /></font>
            </Label>

            <Separator opacity="0.2" prefWidth="155.0" />

            <Button maxWidth="Infinity" prefHeight="33.0" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" onAction="#irAInicio" text="🏠  Inicio">
                <font><Font size="12" /></font>
            </Button>

            <Separator opacity="0.1" prefWidth="155.0" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="530.0" style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-background-color:transparent; -fx-padding: 0 0 4 0;">

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Ventas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAOrdenCliente" text="• Orden de cliente" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAPagoVenta" text="• Registro de pagos de ventas" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAGestionEnvios" text="• Gestión de envíos" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAGestionReclamos" text="• Gestión de reclamos" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="true" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Producción">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irASolicitudProduccion" text="• Solicitud de producción" />
                            <Button maxWidth="Infinity" style="-fx-background-color:#5a2d82; -fx-text-fill:#ffd6ff; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent; -fx-font-weight:bold;" onAction="#irAOrdenProduccion" text="• Orden de producción" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Inventario">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irASalidaMateriales" text="• Salida de materiales para producción" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irASalidaProductos" text="• Salida de productos por ventas" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Compras">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAOrdenProveedor" text="• Orden a proveedor" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAPagoCompra" text="• Registro de pagos por compras" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Registros">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroProducto" text="• Registro de productos" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroEmpleado" text="• Registro de empleado" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroCliente" text="• Registro de cliente" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroSuplidor" text="• Registro de suplidor" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroMaquinaria" text="• Registro de máquinas" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Reportes">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesVentas" text="• Reportes de ventas" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesCompras" text="• Reportes de compras" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesInventario" text="• Reportes de inventario" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesProduccion" text="• Reportes de producción" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Mantenimiento">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAMantenimientoMaquinaria" text="• Mantenimiento de maquinarias" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="🔎  Consultas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAConsultas" text="• Consultas generales" />
                        </VBox>
                    </TitledPane>

                </VBox>
            </ScrollPane>

            <Separator opacity="0.1" />

            <Button maxWidth="Infinity" prefHeight="38" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" onAction="#salir" text="🚪  Salir">
                <font><Font size="13" /></font>
            </Button>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
            <VBox spacing="10" style="-fx-padding: 0 0 16 0; -fx-background-color: #f3eaf8;">

                <StackPane maxWidth="Infinity" style="-fx-border-color:#9b59b6; -fx-border-width:0 0 2 0;">
                    <ImageView fx:id="imgBanner" fitHeight="108.0" fitWidth="830.0" pickOnBounds="true" preserveRatio="false" smooth="true">
                        <image>
                            <Image url="@../com/example/chocolateria/banner.png" />
                        </image>
                    </ImageView>
                </StackPane>

                <VBox spacing="10" style="-fx-padding: 4 20 0 20;">

                    <!-- Tarjeta formulario -->
                    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12;                                  -fx-border-color: #C5A8E8; -fx-border-radius: 12;                                  -fx-padding: 14 18 14 18;                                  -fx-effect: dropshadow(gaussian,rgba(75,41,90,0.10),8,0,0,2);">

                        <Label style="-fx-text-fill:#3B1A5C; -fx-font-size:14px; -fx-font-weight:bold;" text="ORDEN DE PRODUCCIÓN">
                            <font><Font name="Arial" size="12.0" /></font>
                        </Label>
                        <Separator />

                        <!-- Tipo de orden -->
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <VBox minHeight="52" prefWidth="120" spacing="3">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="ID Orden" />
                                <TextField fx:id="txtIdOrden" editable="true" prefHeight="28" promptText="Buscar por ID…" style="-fx-background-color:#f0eaf8; -fx-text-fill:#555;                                                   -fx-border-color:purple; -fx-border-radius:6;                                                   -fx-background-radius:6;" />
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Tipo de orden" />
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <RadioButton fx:id="rbPedido" style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Por pedido de cliente" />
                                    <RadioButton fx:id="rbProduccion" style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Producción propia" />
                                </HBox>
                            </VBox>
                            <!-- Cliente (visible solo si es por pedido) -->
                            <VBox fx:id="vboxCliente" minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="ID Cliente" />
                                <HBox spacing="6">
                                    <TextField fx:id="txtIdCliente" prefHeight="28" prefWidth="80" promptText="ID…" style="-fx-background-color:white; -fx-text-fill:black;                                                       -fx-border-color:purple; -fx-border-radius:6;                                                       -fx-background-radius:6;" />
                                    <Button onAction="#buscarCliente" prefHeight="28" prefWidth="70" style="-fx-background-color:#6d3c87; -fx-text-fill:white;                                                    -fx-font-weight:bold; -fx-background-radius:8;" text="Buscar" />
                                    <Label fx:id="lblNombreCliente" style="-fx-text-fill:#3B1A5C; -fx-font-size:11px; -fx-font-weight:bold;" text="" />
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- Fila: Fecha Orden · Fecha Inicio · Fecha Entrega -->
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Fecha de orden" />
                                <DatePicker fx:id="dpFechaOrden" maxWidth="Infinity" prefHeight="28" style="-fx-background-color:white; -fx-border-color:purple;                                                    -fx-border-radius:6; -fx-background-radius:6;" />
                            </VBox>
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Fecha de inicio" />
                                <DatePicker fx:id="dpFechaInicio" maxWidth="Infinity" prefHeight="28" style="-fx-background-color:white; -fx-border-color:purple;                                                    -fx-border-radius:6; -fx-background-radius:6;" />
                            </VBox>
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Fecha de entrega" />
                                <DatePicker fx:id="dpFechaEntrega" maxWidth="Infinity" prefHeight="28" style="-fx-background-color:white; -fx-border-color:purple;                                                    -fx-border-radius:6; -fx-background-radius:6;" />
                            </VBox>
                        </HBox>

                        <!-- Fila: Responsable · Estado · Prioridad -->
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="ID Responsable" />
                                <HBox spacing="6">
                                    <TextField fx:id="txtIdResponsable" prefHeight="28" prefWidth="70" promptText="ID…" style="-fx-background-color:white; -fx-text-fill:black;                                                       -fx-border-color:purple; -fx-border-radius:6;                                                       -fx-background-radius:6;" />
                                    <Button onAction="#buscarResponsable" prefHeight="28" prefWidth="70" style="-fx-background-color:#6d3c87; -fx-text-fill:white;                                                    -fx-font-weight:bold; -fx-background-radius:8;" text="Buscar" />
                                    <Label fx:id="lblNombreResponsable" style="-fx-text-fill:#3B1A5C; -fx-font-size:11px; -fx-font-weight:bold;" text="" />
                                </HBox>
                            </VBox>
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Estado" />
                                <ComboBox fx:id="cbEstado" maxWidth="Infinity" prefHeight="28" style="-fx-background-color:white; -fx-border-color:purple;                                                  -fx-border-radius:6; -fx-background-radius:6;" />
                            </VBox>
                            <VBox minHeight="52" spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Prioridad" />
                                <ComboBox fx:id="cbPrioridad" maxWidth="Infinity" prefHeight="28" style="-fx-background-color:white; -fx-border-color:purple;                                                  -fx-border-radius:6; -fx-background-radius:6;" />
                            </VBox>
                        </HBox>

                        <!-- Fila: Categorías (checkboxes) · Materiales · Observaciones -->
                        <HBox alignment="TOP_LEFT" spacing="14">
                            <VBox prefWidth="200" spacing="4">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Categoría" />
                                <CheckBox fx:id="chkBombones" style="-fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Bombones" />
                                <CheckBox fx:id="chkTabletas" style="-fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Tabletas" />
                                <CheckBox fx:id="chkTrufas" style="-fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Trufas" />
                                <CheckBox fx:id="chkBaños" style="-fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Baños de chocolate" />
                                <CheckBox fx:id="chkRellenos" style="-fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Rellenos" />
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Materiales requeridos" />
                                <TextArea fx:id="txtMateriales" prefHeight="90" prefWidth="273.0" promptText="Ej: Cacao 5kg, Azúcar 3kg, Leche 2L…" style="-fx-background-color:white; -fx-text-fill:black;                                                  -fx-border-color:purple; -fx-border-radius:6;                                                  -fx-background-radius:6;" />
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight:bold; -fx-font-size:11px; -fx-text-fill:#3B1A5C;" text="Observaciones" />
                                <TextArea fx:id="txtObservaciones" prefHeight="90" prefWidth="491.0" style="-fx-background-color:white; -fx-text-fill:black;                                                  -fx-border-color:purple; -fx-border-radius:6;                                                  -fx-background-radius:6;" />
                            </VBox>
                        </HBox>

                        <Separator />

                        <HBox alignment="CENTER" spacing="10">
                            <Button mnemonicParsing="false" onAction="#guardarOrden" prefHeight="30" prefWidth="100" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Guardar"><font><Font size="11.0" /></font></Button>
                            <Button mnemonicParsing="false" onAction="#fnEditar" prefHeight="30" prefWidth="100" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Editar"><font><Font size="11.0" /></font></Button>
                            <Button mnemonicParsing="false" onAction="#fnEliminar" prefHeight="30" prefWidth="100" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Eliminar"><font><Font size="11.0" /></font></Button>
                            <Button mnemonicParsing="false" onAction="#fnBuscar" prefHeight="30" prefWidth="100" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Buscar"><font><Font size="11.0" /></font></Button>
                            <Button mnemonicParsing="false" onAction="#limpiarCampos" prefHeight="30" prefWidth="100" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Limpiar"><font><Font size="11.0" /></font></Button>
                        </HBox>
                    </VBox>

                    <!-- Tarjeta tabla -->
                    <VBox spacing="7" style="-fx-background-color:white; -fx-background-radius:12;                                  -fx-border-color:#C5A8E8; -fx-border-radius:12;                                  -fx-padding:12 16 12 16;                                  -fx-effect: dropshadow(gaussian,rgba(75,41,90,0.10),8,0,0,2);">

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-text-fill:#3B1A5C; -fx-font-size:12px; -fx-font-weight:bold;" text="Listado de Órdenes" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="txtBuscarTabla" prefWidth="200" promptText="🔍 Buscar por responsable, estado…" style="-fx-background-radius:15; -fx-border-radius:15; -fx-border-color:#C5A8E8;" />
                        </HBox>

                        <TableView fx:id="tablaOrdenes" prefHeight="210" style="-fx-background-radius:10; -fx-border-radius:10;                                           -fx-border-color:#C5A8E8; -fx-background-color:#f3eaf8;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" style="-fx-background-color:#48295a; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:CENTER;" text="ID" />
                                <TableColumn fx:id="colTipo" style="-fx-background-color:#48295a; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:CENTER;" text="Tipo" />
                                <TableColumn fx:id="colCliente" style="-fx-background-color:#48295a; -fx-text-fill:white; -fx-font-weight:bold; -fx-alignment:CENTER;" text="Cliente" />
