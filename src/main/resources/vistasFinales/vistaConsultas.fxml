<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720.0" prefWidth="1020.0" style="-fx-background-color: #f3eaf8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.consultasController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="190.0" spacing="6" style="-fx-background-color:#48295a;">
            <padding><Insets bottom="20" left="10" right="10" top="24" /></padding>

            <StackPane maxHeight="80" maxWidth="80" minHeight="80" minWidth="80">
                <ImageView fx:id="imgFotoPerfil" fitHeight="100.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../com/example/chocolateria/perfilr.png" /></image>
                </ImageView>
            </StackPane>

            <Label alignment="CENTER" prefHeight="20.0" prefWidth="91.0" style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Rosalin Aybar" wrapText="true">
                <font><Font name="Courier New" size="10" /></font>
            </Label>

            <Separator opacity="0.2" prefWidth="155.0" />
            <Button maxWidth="Infinity" prefHeight="33.0" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="&#127968;  Inicio">
                <font><Font size="12" /></font>
            </Button>
            <Separator opacity="0.1" prefWidth="155.0" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="530.0" style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-background-color:transparent; -fx-padding: 0 0 4 0;">

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Ventas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAOrdenCliente" text="• Orden de cliente" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAPagoVenta" text="• Registro de pagos de ventas" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Gestion de envios" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Gestion de reclamos" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Produccion">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Solicitud de produccion" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Orden de produccion" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Compras">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAOrdenProveedor" text="• Orden a proveedor" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Recepcion de productos" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAPagoCompra" text="• Registro de pagos por compras" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Inventario">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Salida de materiales" wrapText="true" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Salida de productos" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Registros">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroProducto" text="• Registro de productos" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroEmpleado" text="• Registro de empleado" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroCliente" text="• Registro de cliente" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irARegistroSuplidor" text="• Registro de suplidor" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de maquinas" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Reportes">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesVentas" text="• Reportes de ventas" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesCompras" text="• Reportes de compras" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAReportesInventario" text="• Reportes de inventario" />
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Reportes de produccion" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Mantenimiento">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" onAction="#irAMantenimientoMaquinaria" text="• Mantenimiento de maquinarias" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane animated="true" expanded="true" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Consultas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" style="-fx-background-color:#5a2d82; -fx-text-fill:#ffd6ff; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent; -fx-font-weight:bold;" onAction="#irAConsultas" text="• Consultas generales" />
                        </VBox>
                    </TitledPane>

                </VBox>
            </ScrollPane>

            <Separator opacity="0.1" />
            <Button maxWidth="Infinity" prefHeight="38" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="&#128682;  Salir">
                <font><Font size="13" /></font>
            </Button>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="10" style="-fx-padding: 0 0 16 0; -fx-background-color: #f3eaf8;">

                <StackPane maxWidth="Infinity" style="-fx-border-color:#9b59b6; -fx-border-width:0 0 2 0;">
                    <ImageView fx:id="imgBanner" fitHeight="105.0" fitWidth="830.0" pickOnBounds="true" preserveRatio="false" smooth="true">
                        <image><Image url="@../com/example/chocolateria/banner.png" /></image>
                    </ImageView>
                </StackPane>

                <VBox spacing="10" style="-fx-padding: 4 20 0 20;">

                    <!-- Titulo + buscador general -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-text-fill:#3B1A5C; -fx-font-size:16px; -fx-font-weight:bold;" text="CONSULTAS GENERALES" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtBuscarGeneral" prefWidth="220" promptText="Buscar en la consulta activa..."
                                   style="-fx-background-radius:15; -fx-border-radius:15; -fx-border-color:#C5A8E8;" />
                        <Button onAction="#ejecutarBusqueda" prefHeight="28" prefWidth="80"
                                style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="Buscar" />
                        <Button onAction="#limpiarBusqueda" prefHeight="28" prefWidth="80"
                                style="-fx-background-color:#48295a; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="Limpiar" />
                    </HBox>

                    <!-- Botones de consulta -->
                    <VBox spacing="6" style="-fx-background-color:white; -fx-background-radius:12; -fx-border-color:#C5A8E8; -fx-border-radius:12; -fx-padding:14 18 14 18; -fx-effect: dropshadow(gaussian,rgba(75,41,90,0.10),8,0,0,2);">
                        <Label style="-fx-text-fill:#3B1A5C; -fx-font-size:12px; -fx-font-weight:bold;" text="Selecciona una consulta" />
                        <Separator />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnClientes"    onAction="#consultarClientes"    prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128100; Clientes"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnVentas"      onAction="#consultarVentas"      prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128176; Ventas"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnCompras"     onAction="#consultarCompras"     prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128722; Compras"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnProduccion"  onAction="#consultarProduccion"  prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#127981; Produccion"><font><Font size="11" /></font></Button>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnInventario"  onAction="#consultarInventario"  prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128230; Inventario"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnPedidos"     onAction="#consultarPedidos"     prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128203; Pedidos"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnIngresos"    onAction="#consultarIngresos"    prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#2e7d32; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128200; Reporte Ingresos"><font><Font size="11" /></font></Button>
                            <Button fx:id="btnMasVendidos" onAction="#consultarMasVendidos" prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#2e7d32; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#11088; Mas Vendidos"><font><Font size="11" /></font></Button>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="btnMantenimiento" onAction="#consultarMantenimiento" prefHeight="34" prefWidth="155"
                                    style="-fx-background-color:#48295a; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:10;" text="&#128295; Mantenimiento"><font><Font size="11" /></font></Button>
                        </HBox>
                    </VBox>

                    <!-- Label consulta activa -->
                    <Label fx:id="lblConsultaActiva" style="-fx-text-fill:#3B1A5C; -fx-font-size:12px; -fx-font-weight:bold;" text="" />

                    <!-- Tabla resultado -->
                    <VBox spacing="7" style="-fx-background-color:white; -fx-background-radius:12; -fx-border-color:#C5A8E8; -fx-border-radius:12; -fx-padding:12 16 12 16; -fx-effect: dropshadow(gaussian,rgba(75,41,90,0.10),8,0,0,2);">
                        <TableView fx:id="tablaResultados" prefHeight="380"
                                   style="-fx-background-radius:10; -fx-border-radius:10; -fx-border-color:#C5A8E8; -fx-background-color:#f3eaf8;" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <placeholder>
                                <Label text="Selecciona una consulta para ver los resultados" style="-fx-text-fill:#888; -fx-font-size:13px;" />
                            </placeholder>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <Label fx:id="lblTotal" style="-fx-text-fill:#3B1A5C; -fx-font-size:11px; -fx-font-weight:bold;" text="" />
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
