<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="720.0" prefWidth="1020.0" style="-fx-background-color: #f3eaf8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.inicioController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="190.0" spacing="6" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="10" right="10" top="24" />
            </padding>

            <StackPane maxHeight="80" maxWidth="80" minHeight="80" minWidth="80">
                <ImageView fx:id="imgFotoPerfil" fitHeight="100.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../com/example/chocolateria/perfilr.png" />
                    </image>
                </ImageView>
            </StackPane>

            <Label fx:id="lblUsuario" alignment="CENTER" prefWidth="160.0" style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="" wrapText="true">
                <font><Font name="Courier New" size="10" /></font>
            </Label>

            <Separator opacity="0.2" prefWidth="155.0" />

            <Button maxWidth="Infinity" onAction="#irAInicio" prefHeight="33.0" style="-fx-background-color:#5a2d82; -fx-text-fill:#ffd6ff; -fx-font-weight:bold; -fx-background-radius:14; -fx-border-color:#c084fc; -fx-border-radius:14; -fx-border-width:1.5;" text="🏠  Inicio">
                <font><Font size="12" /></font>
            </Button>

            <Separator opacity="0.1" prefWidth="155.0" />

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="530.0" style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-background-color:transparent; -fx-padding: 0 0 4 0;">

                    <TitledPane fx:id="paneVentas" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Ventas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnOrdenCliente"    maxWidth="Infinity" onAction="#irAOrdenCliente" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Orden de cliente" />
                            <Button fx:id="btnPagoVenta"       maxWidth="Infinity" onAction="#irAPagoVenta" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de pagos de ventas" wrapText="true" />
                            <Button fx:id="btnGestionEnvios"   maxWidth="Infinity" onAction="#irAGestionEnvios" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Gestión de envíos" />
                            <Button fx:id="btnGestionReclamos" maxWidth="Infinity" onAction="#irAGestionReclamos" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Gestión de reclamos" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneProduccion" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Producción">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnSolicitudProduccion" maxWidth="Infinity" onAction="#irASolicitudProduccion" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Solicitud de producción" />
                            <Button fx:id="btnOrdenProduccion"     maxWidth="Infinity" onAction="#irAOrdenProduccion" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Orden de producción" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneInventario" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Inventario">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnSalidaMateriales" maxWidth="Infinity" onAction="#irASalidaMateriales" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Salida de materiales para producción" wrapText="true" />
                            <Button fx:id="btnSalidaProductos"  maxWidth="Infinity" onAction="#irASalidaProductos" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Salida de productos por ventas" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneCompras" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Compras">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnOrdenProveedor" maxWidth="Infinity" onAction="#irAOrdenProveedor" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Orden a proveedor" />
                            <Button fx:id="btnPagoCompra"     maxWidth="Infinity" onAction="#irAPagoCompra" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de pagos por compras" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneRegistros" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Registros">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnRegProducto"  maxWidth="Infinity" onAction="#irARegistroProducto" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de productos" />
                            <Button fx:id="btnRegEmpleado"  maxWidth="Infinity" onAction="#irARegistroEmpleado" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de empleado" />
                            <Button fx:id="btnRegCliente"   maxWidth="Infinity" onAction="#irARegistroCliente" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de cliente" />
                            <Button fx:id="btnRegSuplidor"  maxWidth="Infinity" onAction="#irARegistroSuplidor" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de suplidor" />
                            <Button fx:id="btnRegMaquinaria" maxWidth="Infinity" onAction="#irARegistroMaquinaria" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Registro de máquinas" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneReportes" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Reportes">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" onAction="#irAReportesVentas"    style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Reportes de ventas" />
                            <Button maxWidth="Infinity" onAction="#irAReportesCompras"   style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Reportes de compras" />
                            <Button maxWidth="Infinity" onAction="#irAReportesInventario" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Reportes de inventario" />
                            <Button maxWidth="Infinity" onAction="#irAReportesProduccion" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Reportes de producción" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneMantenimiento" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="Mantenimiento">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button fx:id="btnMantenimientoMaquinaria" maxWidth="Infinity" onAction="#irAMantenimientoMaquinaria" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Mantenimiento de maquinarias" wrapText="true" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneConsultas" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="🔎  Consultas">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" onAction="#irAConsultas" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Consultas generales" />
                        </VBox>
                    </TitledPane>

                    <TitledPane fx:id="paneAdministracion" animated="true" expanded="false" style="-fx-base:#3d1055; -fx-background-color:#3d1055; -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:11px;" text="⚙  Administración">
                        <VBox spacing="1" style="-fx-background-color:#2a0a3a; -fx-padding:4 0 4 0;">
                            <Button maxWidth="Infinity" onAction="#irAGestionUsuarios" style="-fx-background-color:transparent; -fx-text-fill:#e8d5f5; -fx-font-size:10px; -fx-alignment:CENTER_LEFT; -fx-padding:4 8 4 16; -fx-border-color:transparent;" text="• Gestión de usuarios" />
                        </VBox>
                    </TitledPane>

                </VBox>
            </ScrollPane>

            <Separator opacity="0.1" />

            <Button maxWidth="Infinity" onAction="#salir" prefHeight="38" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="🚪  Salir">
                <font><Font size="13" /></font>
            </Button>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
            <VBox spacing="0" style="-fx-background-color: #f3eaf8;">

                <StackPane maxWidth="Infinity" style="-fx-border-color:#9b59b6; -fx-border-width:0 0 2 0;">
                    <ImageView fitHeight="119.0" fitWidth="830.0" pickOnBounds="true" preserveRatio="false" smooth="true">
                        <image>
                            <Image url="@../com/example/chocolateria/banner.png" />
                        </image>
                    </ImageView>
                </StackPane>

                <VBox spacing="20" style="-fx-padding: 20 24 24 24;">

                    <HBox alignment="CENTER_LEFT" prefWidth="782.0" spacing="16" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #C5A8E8; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-padding: 20 24 20 24; -fx-effect: dropshadow(gaussian,rgba(75,41,90,0.13),10,0,0,3);">
                        <VBox prefHeight="79.0" prefWidth="497.0" spacing="6" HBox.hgrow="ALWAYS">
                            <Label prefHeight="50.0" prefWidth="430.0" style="-fx-text-fill:#3B1A5C; -fx-font-size:22px; -fx-font-weight:bold;" text="Bienvenido al sistema" textAlignment="CENTER">
                                <font><Font name="Candara Light" size="14.0" /></font>
                            </Label>
                            <Label prefHeight="28.0" prefWidth="309.0" style="-fx-text-fill:#8b5aa6; -fx-font-size:19px;" text="CHOCOLATERÍA — Panel de control" />
                            <Label style="-fx-text-fill:#888888; -fx-font-size:11px;" text="Selecciona un módulo del menú lateral o usa los accesos rápidos." />
                            <HBox alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 5 10 5 10; -fx-background-color:#f3eaf8; -fx-background-radius:8;">
                                <StackPane>
                                    <Label prefHeight="41.0" prefWidth="24.0" style="-fx-font-size: 12px; -fx-text-fill: #48295a;" text="📅" textFill="#601d66">
                                        <font><Font size="14.0" /></font>
                                    </Label>
                                </StackPane>
                                <Label fx:id="lblFecha" style="-fx-text-fill:#6d3c87; -fx-font-size:12px; -fx-font-weight:bold;" text="" />
                            </HBox>
                        </VBox>
                        <StackPane>
                            <ImageView fitHeight="122.0" fitWidth="222.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@../com/example/chocolateria/logo.png" />
                                </image>
                                <effect>
                                    <Lighting diffuseConstant="2.0">
                                        <bumpInput>
                                            <Reflection>
                                                <input><MotionBlur /></input>
                                            </Reflection>
                                        </bumpInput>
                                        <light><Light.Distant /></light>
                                    </Lighting>
                                </effect>
                            </ImageView>
                        </StackPane>
                    </HBox>

                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-size:14px; -fx-font-weight:bold;" text="Acceso rápido">
                        <font><Font name="Arial" size="14.0" /></font>
                    </Label>

                    <FlowPane fx:id="flowCards" hgap="16" vgap="16" prefWrapLength="760">

                        <Button fx:id="cardVentas" prefWidth="225" prefHeight="130" onAction="#cardVentas" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#8b5aa6; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(139,90,166,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label prefHeight="40" prefWidth="40" style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="🛒" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Ventas" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Órdenes y pagos" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cardProduccion" prefWidth="225" prefHeight="130" onAction="#cardProduccion" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#6d3c87; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(109,60,135,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="🏭" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Producción" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Solicitudes y órdenes" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cardInventario" prefWidth="225" prefHeight="130" onAction="#cardInventario" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#5a2d82; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(90,45,130,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="📦" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Inventario" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Recepciones y salidas" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cardCompras" prefWidth="225" prefHeight="130" onAction="#cardCompras" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#48295a; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(72,41,90,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="🛍" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Compras" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Proveedores y pagos" />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cardRegistros" prefWidth="225" prefHeight="130" onAction="#cardRegistros" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#9b59b6; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(155,89,182,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="📋" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Registros" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Clientes, empleados..." />
                                </VBox>
                            </graphic>
                        </Button>

                        <Button fx:id="cardReportes" prefWidth="225" prefHeight="130" onAction="#cardReportes" style="-fx-background-color:white; -fx-background-radius:16; -fx-border-color:#3d1055; -fx-border-radius:16; -fx-border-width:2; -fx-padding:18 12 18 12; -fx-effect:dropshadow(gaussian,rgba(61,16,85,0.18),8,0,0,3); -fx-cursor:hand;">
                            <graphic>
                                <VBox alignment="CENTER" spacing="6">
                                    <StackPane><Label style="-fx-font-size:32px; -fx-text-fill:#48295a;" text="📊" /></StackPane>
                                    <Label style="-fx-text-fill:#3B1A5C; -fx-font-weight:bold; -fx-font-size:13px;" text="Reportes" />
                                    <Label style="-fx-text-fill:#888888; -fx-font-size:10px;" text="Análisis y consultas" />
                                </VBox>
                            </graphic>
                        </Button>

                    </FlowPane>

                    <HBox alignment="CENTER">
                        <Label style="-fx-text-fill:#b89fcf; -fx-font-size:10px;" text="Chocolatería  •  Sistema de Gestión  " />
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
