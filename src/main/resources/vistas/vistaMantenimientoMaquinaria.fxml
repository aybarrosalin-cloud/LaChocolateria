<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.mantenimientoMaquinariaController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="534.0" prefWidth="121.0" spacing="16" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="45" />
            </padding>

            <Button maxWidth="Infinity" prefHeight="46" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Inicio" />
            <Button maxWidth="Infinity" prefHeight="28.0" prefWidth="91.0" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Maquina. M " />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Inventario" />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Maquinaria" />

            <Region VBox.vgrow="ALWAYS" />
            <Separator opacity="0.1" />
            <Label style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Yara Disla 7">
                <font><Font name="Courier New" size="10" /></font>
            </Label>

            <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Salir" />
        </VBox>
    </left>


    <center>
        <StackPane>


            <ImageView fitHeight="533.0" fitWidth="949.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                <image>
                    <Image url="@../com/example/chocolateria/MantenimientoMaquinaria.png" />
                </image>
            </ImageView>


            <GridPane alignment="CENTER" hgap="45" vgap="10">
                <StackPane.margin>
                    <Insets top="100" />
                </StackPane.margin>


                <Label style="-fx-font-weight:bold;" text="Fecha mantenimiento" />
                <DatePicker fx:id="dpFechaMantenimiento" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.rowIndex="1" />


                <Label style="-fx-font-weight:bold;" text="Máquina" GridPane.columnIndex="1" />
                <ChoiceBox fx:id="cbMaquina" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight:bold;" text="Técnico responsable" GridPane.columnIndex="2" />
                <ChoiceBox fx:id="cbTecnico" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="2" GridPane.rowIndex="1" />


                <Label style="-fx-font-weight:bold;" text="Costo del mantenimiento" GridPane.rowIndex="2" />
                <TextField fx:id="txtCosto" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.rowIndex="3" />


                <Label style="-fx-font-weight:bold;" text="Estado de la máquina" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <ChoiceBox fx:id="cbEstadoMaquina" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="3" />


                <Label style="-fx-font-weight:bold;" text="Tipo de mantenimiento" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <ChoiceBox fx:id="cbTipoMantenimiento" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="2" GridPane.rowIndex="3" />


                <Label style="-fx-font-weight:bold;" text="Observaciones" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <TextArea fx:id="taObservaciones" prefHeight="70" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <columnConstraints>
                    <ColumnConstraints minWidth="100" />
                    <ColumnConstraints />
                    <ColumnConstraints />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>

            </GridPane>


            <HBox alignment="BOTTOM_CENTER" pickOnBounds="false" spacing="30">
                <StackPane.margin>
                    <Insets bottom="35" />
                </StackPane.margin>


                <Button fx:id="btnGuardar" mouseTransparent="false" onAction="#guardarMantenimiento" prefHeight="30.0" prefWidth="121.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Guardar">
                    <font><Font size="14.0" /></font>
                </Button>

                <Button fx:id="btnEditar" mouseTransparent="false" prefHeight="29.0" prefWidth="129.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Editar">
                    <font><Font size="14.0" /></font>
                </Button>

                <Button fx:id="btnLimpiar" mouseTransparent="false" onAction="#LimpiarCampos" prefHeight="31.0" prefWidth="132.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Limpiar">
                    <font><Font size="14.0" /></font>
                </Button>

            </HBox>

        </StackPane>
    </center>

</BorderPane>
