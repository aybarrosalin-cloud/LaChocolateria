<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= MENU IZQUIERDO ================= -->
    <left>
        <VBox alignment="TOP_CENTER" spacing="16" style="-fx-background-color:#48295a;">
            <padding>
                <Insets top="45" left="15" right="15" bottom="20"/>
            </padding>

            <Button maxWidth="Infinity" prefHeight="46"
                    style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;"
                    text="Inicio"/>

            <Button maxWidth="Infinity" prefHeight="52"
                    style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;"
                    text="ORDEN DE&#10;CLIENTE"/>

            <Button maxWidth="Infinity"
                    style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;"
                    text="Clientes"/>

            <Button maxWidth="Infinity"
                    style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;"
                    text="Pedidos"/>

            <!-- ESTO HACE QUE BAJE HASTA EL FINAL -->
            <Region VBox.vgrow="ALWAYS"/>

            <Separator opacity="0.2"/>

            <Label style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Yara Disla 7"/>

            <Button maxWidth="Infinity" prefHeight="42"
                    style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;"
                    text="Salir"/>
        </VBox>
    </left>

    <!-- ================= CENTRO CON SCROLL ================= -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background:#F5F0FA;">
            <content>

                <VBox spacing="20" style="-fx-background-color:#F5F0FA; -fx-padding:10;">

                    <!-- IMAGEN PRINCIPAL -->
                    <StackPane>
                        <ImageView fitHeight="500" preserveRatio="true">
                            <image>
                                <Image url="@../com/example/chocolateria/OrdenDeCliente.png"/>
                            </image>
                        </ImageView>
                    </StackPane>

                    <!-- TABLA ABAJO -->
                    <StackPane
                            style="-fx-background-image: url('@../com/example/chocolateria/fondo simple.png');
                               -fx-background-size: cover;
                               -fx-background-position: center;">

                        <VBox spacing="10"
                              style="-fx-background-color:white;
                                     -fx-background-radius:15;
                                     -fx-border-radius:15;
                                     -fx-padding:20;">
                            <StackPane.margin>
                                <Insets top="20" bottom="20" left="20" right="20"/>
                            </StackPane.margin>

                            <Label text="Órdenes registradas"
                                   style="-fx-font-weight:bold; -fx-font-size:14;"/>

                            <TableView prefHeight="300"
                                       style="-fx-background-radius:10; -fx-border-radius:10;">
                                <columns>
                                    <TableColumn text="Código"/>
                                    <TableColumn text="Cliente"/>
                                    <TableColumn text="Fecha"/>
                                    <TableColumn text="Producto"/>
                                    <TableColumn text="Cantidad"/>
                                </columns>

                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>

                        </VBox>
                    </StackPane>

                </VBox>

            </content>
        </ScrollPane>
    </center>

    <!-- ================= PANEL DERECHO ================= -->
    <right>
        <StackPane
                style="-fx-background-image: url('@../com/example/chocolateria/fondo simple.png');
                   -fx-background-size: cover;
                   -fx-background-position: center;">

            <VBox spacing="10"
                  prefWidth="260"
                  style="-fx-background-color:white;
                         -fx-background-radius:15;
                         -fx-border-radius:15;
                         -fx-padding:20;">

                <!-- MARGEN PARA QUE SE VEA LA IMAGEN -->
                <StackPane.margin>
                    <Insets top="20" bottom="20" left="20" right="20"/>
                </StackPane.margin>

                <Label text="Agregar Producto"
                       style="-fx-font-weight:bold; -fx-font-size:14;"/>

                <Separator/>

                <TextField promptText="ID Producto"/>
                <TextField promptText="Nombre"/>
                <TextField promptText="Cantidad"/>
                <TextField promptText="Precio"/>

                <HBox spacing="10">
                    <Button text="Buscar"
                            style="-fx-background-color:#8B5DBF; -fx-text-fill:white; -fx-background-radius:15;"/>

                    <Button text="Agregar"
                            style="-fx-background-color:#5A2D90; -fx-text-fill:white; -fx-background-radius:15;"/>

                    <Button text="Eliminar"
                            style="-fx-background-color:#C04A5A; -fx-text-fill:white; -fx-background-radius:15;"/>
                </HBox>

            </VBox>

        </StackPane>
    </right>

</BorderPane>