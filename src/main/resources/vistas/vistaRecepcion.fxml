<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.recepcionController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="534.0" prefWidth="121.0" spacing="16" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="45" />
            </padding>
            <Button maxWidth="Infinity" prefHeight="46" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Inicio">
                <font><Font size="18.0" /></font>
            </Button>
            <Button maxWidth="Infinity" prefHeight="52.0" prefWidth="91.0" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Recepción &#10;" />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Clientes" />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Pedidos" />
            <Region prefHeight="159.0" prefWidth="63.0" VBox.vgrow="ALWAYS" />
            <Separator opacity="0.1" />
            <Label style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Yara Disla 7">
                <font><Font name="Courier New" size="10.0" /></font>
            </Label>
            <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Salir">
                <font><Font size="18.0" /></font>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane>
            <ImageView fitHeight="533.0" fitWidth="949.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                <image>
                    <Image url="@../com/example/chocolateria/fondoRecepcion.png" />
                </image>
            </ImageView>

            <GridPane alignment="CENTER" hgap="45" prefHeight="376.0" prefWidth="914.0" vgap="10">
                <StackPane.margin>
                    <Insets top="50.0" />
                </StackPane.margin>

                <DatePicker fx:id="dpFechaRecepcion" prefHeight="30.0" prefWidth="268.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label prefHeight="20.0" prefWidth="131.0" style="-fx-font-weight:bold;" text="Fecha recepción" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>

                <Label style="-fx-font-weight:bold;" text="Número de orden" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>

                <Label style="-fx-font-weight:bold;" text="Monto por producto" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtMontoPorProducto" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight:bold;" text="Precio unitario real" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtPrecioUnitario" prefHeight="30.0" prefWidth="202.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.rowIndex="5">
                    <GridPane.margin><Insets bottom="35.0" /></GridPane.margin>
                </TextField>

                <Label style="-fx-font-weight:bold;" text="Observaciones" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtObservaciones" prefHeight="66.0" prefWidth="270.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label layoutX="284.0" layoutY="150.0" prefHeight="20.0" prefWidth="125.0" style="-fx-font-weight:bold;" text="RNC Proveedor">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtRncProveedor" layoutX="284.0" layoutY="180.0" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.rowIndex="1" />

                <Label layoutX="113.0" layoutY="150.0" prefHeight="20.0" prefWidth="146.0" style="-fx-font-weight:bold;" text="Producto/s recibido/s" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>

                <Label layoutX="308.0" layoutY="132.0" prefHeight="20.0" prefWidth="131.0" style="-fx-font-weight:bold;" text="Monto total" GridPane.rowIndex="4">
                    <font><Font size="14" /></font>
                </Label>

                <TextField fx:id="txtCantidadRecibida" prefHeight="27.0" prefWidth="269.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="2" GridPane.rowIndex="5">
                    <GridPane.margin><Insets top="-40.0" /></GridPane.margin>
                </TextField>

                <TextField fx:id="txtNumeroOrden" layoutX="323.0" layoutY="234.0" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <Label layoutX="289.0" layoutY="204.0" style="-fx-font-weight:bold;" text="Cantidad recibida" GridPane.columnIndex="2" GridPane.rowIndex="4">
                    <font><Font size="14" /></font>
                </Label>

                <TextField fx:id="txtProductos" layoutX="94.0" layoutY="163.0" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.rowIndex="3">
                    <GridPane.margin><Insets /></GridPane.margin>
                </TextField>

                <TextField fx:id="txtMontoTotal" layoutX="289.0" layoutY="234.0" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                <columnConstraints>
                    <ColumnConstraints minWidth="100.0" prefWidth="150.0" />
                    <ColumnConstraints />
                    <ColumnConstraints hgrow="NEVER" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints /><RowConstraints /><RowConstraints />
                    <RowConstraints /><RowConstraints /><RowConstraints />
                </rowConstraints>
            </GridPane>

            <HBox alignment="BOTTOM_CENTER" pickOnBounds="false" prefHeight="401.0" prefWidth="948.0" spacing="30.0">
                <StackPane.margin>
                    <Insets bottom="35.0" />
                </StackPane.margin>
                <Button mnemonicParsing="false" onAction="#guardarRecepcion" prefHeight="35.0" prefWidth="105.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Guardar">
                    <font><Font size="14.0" /></font>
                </Button>
                <Button mnemonicParsing="false" onAction="#limpiarCampos" prefHeight="35.0" prefWidth="106.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Limpiar">
                    <font><Font size="14.0" /></font>
                </Button>
            </HBox>

        </StackPane>
    </center>

</BorderPane>
