<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.ordenClienteController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="534.0" prefWidth="104.0" spacing="16" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="45" />
            </padding>

            <Button maxWidth="Infinity" prefHeight="46" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Inicio">
                <font>
                    <Font size="18.0" />
                </font>
            </Button>

            <Button maxWidth="Infinity" prefHeight="52.0" prefWidth="91.0" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="ORDEN DE&#10;CLIENTE" />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Clientes" />
            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:#f5f0f7; -fx-font-weight:bold; -fx-background-radius:12;" text="Pedidos" />

            <Region prefHeight="159.0" prefWidth="63.0" VBox.vgrow="ALWAYS" />
            <Separator opacity="0.1" />

            <Label style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Yara Disla 7">
                <font>
                    <Font name="Courier New" size="10.0" />
                </font>
            </Label>

            <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Salir">
                <font>
                    <Font size="18.0" />
                </font>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane>
            <ImageView fitHeight="533.0" fitWidth="949.0" preserveRatio="true">
                <image>
                    <Image url="@../com/example/chocolateria/OrdenDeCliente.png" />
                </image>
            </ImageView>

            <GridPane alignment="CENTER" hgap="45" prefHeight="376.0" prefWidth="914.0" vgap="10">
                <StackPane.margin>
                    <Insets top="50.0" />
                </StackPane.margin>
                <DatePicker fx:id="dpFecha" prefHeight="30.0" prefWidth="242.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <Label prefHeight="20.0" prefWidth="152.0" style="-fx-font-weight:bold;" text="Cliente" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>

                <Label style="-fx-font-weight:bold;" text="Fecha" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>

                <Label style="-fx-font-weight:bold;" text="Cantidad" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>
                <Label layoutX="284.0" layoutY="150.0" prefHeight="20.0" prefWidth="125.0" style="-fx-font-weight:bold;" text="Código">
                    <font>
                        <Font size="14" />
                    </font>
                </Label>
                <TextField fx:id="txtCodigo" layoutX="284.0" layoutY="180.0" prefHeight="30.0" prefWidth="270" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.rowIndex="1" />
                <Label layoutX="113.0" layoutY="150.0" prefHeight="20.0" prefWidth="146.0" style="-fx-font-weight:bold;" text="Productos" GridPane.rowIndex="2">
                    <font>
                        <Font size="14" />
                    </font>
                </Label>
                <Label layoutX="308.0" layoutY="132.0" prefHeight="20.0" prefWidth="131.0" style="-fx-font-weight:bold;" text="Estado" GridPane.rowIndex="4">
                    <font>
                        <Font size="14" />
                    </font>
                </Label>
                <Label layoutX="289.0" layoutY="133.0" prefHeight="20.0" prefWidth="152.0" style="-fx-font-weight:bold;" text="Categoría" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font>
                        <Font size="14" />
                    </font>
                </Label>
                <ComboBox fx:id="cmbCliente" layoutX="605.0" layoutY="184.0" prefHeight="27.0" prefWidth="237.0" style="-fx-text-fill: black; -fx-background-color: white; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <ChoiceBox fx:id="cbEstado" layoutX="95.0" layoutY="324.0" prefHeight="27.0" prefWidth="236.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.rowIndex="5" />
            <ComboBox fx:id="cmbCategoria" layoutX="307.0" layoutY="186.0" prefHeight="27.0" prefWidth="237.0" style="-fx-text-fill: black; -fx-background-color: white; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <ChoiceBox fx:id="cbMetodoPago" layoutX="111.0" layoutY="256.0" prefHeight="27.0" prefWidth="237.0" style="-fx-background-color: white; -fx-text-fill: black; -fx-border-color: purple;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label layoutX="111.0" layoutY="154.0" prefHeight="20.0" prefWidth="125.0" style="-fx-font-weight:bold;" text="Método de pago" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <font>
                  <Font size="14" />
               </font>
            </Label>
            <ComboBox fx:id="cmbProducto" layoutX="307.0" layoutY="186.0" prefHeight="27.0" prefWidth="237.0" style="-fx-text-fill: black; -fx-background-color: white; -fx-border-color: purple;" GridPane.rowIndex="3" />
            <Spinner fx:id="spCantidad" prefHeight="27.0" prefWidth="241.0" style="-fx-text-fill: black; -fx-background-color: white; -fx-border-color: purple;" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                <columnConstraints>
                    <ColumnConstraints minWidth="100.0" prefWidth="150.0" />
                    <ColumnConstraints />
                    <ColumnConstraints hgrow="NEVER" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>

            <HBox alignment="BOTTOM_CENTER" pickOnBounds="false" spacing="30.0">
                <StackPane.margin>
                    <Insets bottom="35.0" />
                </StackPane.margin>
                <children>
                    <Button mnemonicParsing="false" onAction="#guardar" prefHeight="35.0" prefWidth="105.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Guardar">
                        <font><Font size="14.0" /></font>
                    </Button>

                    <Button mnemonicParsing="false" onAction="#fnEditar" prefHeight="35.0" prefWidth="108.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Editar">
                        <font><Font size="14.0" /></font>
                    </Button>

                    <Button mnemonicParsing="false" onAction="#limpiarCampos" prefHeight="35.0" prefWidth="106.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Limpiar">
                        <font><Font size="14.0" /></font>
                    </Button>
               <Button layoutX="636.0" layoutY="474.0" mnemonicParsing="false" onAction="#fnbuscar" prefHeight="35.0" prefWidth="106.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Buscar">
                  <font>
                     <Font size="14.0" />
                  </font>
               </Button>
                </children>
            </HBox>
        </StackPane>
    </center>
   <bottom>
       <StackPane style="     -fx-background-image: url('@../com/example/chocolateria/fondo simple.png');     -fx-background-size: cover;     -fx-background-position: center;     -fx-background-repeat: no-repeat; ">
           <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #C5A8E8; -fx-border-radius: 10; -fx-padding: 15;" VBox.vgrow="ALWAYS">

               <HBox alignment="CENTER_LEFT" spacing="10">
                   <Label style="-fx-text-fill: #3B1A5C; -fx-font-size: 14px; -fx-font-weight: bold;" text="Orden de cliente " />

                   <Region HBox.hgrow="ALWAYS" />

                   <TextField promptText="🔍 Buscar..." style="-fx-background-radius: 15; -fx-border-radius: 15;" />
               </HBox>

               <TableView fx:id="tablaProductos" prefHeight="300" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #C5A8E8;" VBox.vgrow="ALWAYS">

                   <columns>
                       <TableColumn text="Código" />
                       <TableColumn text="Cliente" />
                       <TableColumn text="Fecha" />
                       <TableColumn text="Producto(s)" />
                       <TableColumn text="Cantidad" />
                       <TableColumn text="Estado" />
                       <TableColumn text="Método Pago" />
                   </columns>

                   <columnResizePolicy>
                       <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                   </columnResizePolicy>

               </TableView>

           </VBox>

       </StackPane>   </bottom>
   <right>
       <StackPane style="     -fx-background-image: url('@../com/example/chocolateria/fondo simple.png');     -fx-background-size: cover;     -fx-background-position: center;     -fx-background-repeat: no-repeat;">

           <VBox prefWidth="244.0" spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #C5A8E8; -fx-border-radius: 10; -fx-padding: 15;">

               <Label style="-fx-text-fill: #3B1A5C; -fx-font-size: 14px; -fx-font-weight: bold;" text="Agregar Producto" />

               <Separator />

               <GridPane hgap="10" vgap="8">

                   <Label text="ID Producto" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                   <TextField fx:id="txtIdProducto" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                   <Label text="Nombre" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                   <TextField fx:id="txtNombreProducto" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                   <Label text="Cantidad" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                   <TextField fx:id="txtCantidad" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                   <Label text="Precio" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                   <TextField fx:id="txtPrecio" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>

               </GridPane>

               <HBox spacing="10">
                   <Button style="-fx-background-color: #8B5DBF; -fx-text-fill: white; -fx-background-radius: 15;" text="Buscar" />

                   <Button style="-fx-background-color: #5A2D90; -fx-text-fill: white; -fx-background-radius: 15;" text="Agregar" />

                   <Button style="-fx-background-color: #C04A5A; -fx-text-fill: white; -fx-background-radius: 15;" text="Eliminar" />
               </HBox>

           </VBox>

       </StackPane>   </right>

</BorderPane>
