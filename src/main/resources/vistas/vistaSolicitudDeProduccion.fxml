<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.controller.solicitudProduccionController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="534.0" prefWidth="121.0" spacing="16" style="-fx-background-color:#48295a;">
            <padding>
                <Insets bottom="20" left="15" right="15" top="45" />
            </padding>

            <Button maxWidth="Infinity" prefHeight="46" style="-fx-background-color:#8b5aa6; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Inicio">
                <font><Font size="18" /></font>
            </Button>

            <Button maxWidth="Infinity" prefHeight="38.0" prefWidth="101.0" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="S.Produccion" />

            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Inventario" />

            <Button maxWidth="Infinity" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Pedidos" />

            <Region VBox.vgrow="ALWAYS" />

            <Separator opacity="0.1" />

            <Label style="-fx-text-fill:#eadcf2; -fx-font-weight:bold;" text="Yara Disla 7">
                <font><Font name="Courier New" size="10" /></font>
            </Label>

            <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#a83c5b; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:14;" text="Salir" />
        </VBox>
    </left>

    <center>

        <StackPane>


            <ImageView fitHeight="533" fitWidth="949" mouseTransparent="true" preserveRatio="true">
                <image>
                    <Image url="@../com/example/chocolateria/SolicitudDeProduccion.png" />
                </image>
            </ImageView>

            <GridPane alignment="CENTER" hgap="45" mouseTransparent="false" pickOnBounds="false" vgap="10" viewOrder="-1">
                <StackPane.margin>
                    <Insets top="100" />
                </StackPane.margin>


                <Label style="-fx-font-weight:bold;" text="Código de la solicitud" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtCodigoProducto" prefWidth="270" style="-fx-background-color:white; -fx-text-fill:black; -fx-border-color:purple;" GridPane.columnIndex="0" GridPane.rowIndex="1" />


                <Label style="-fx-font-weight:bold;" text="Producto a producir" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <font><Font size="14" /></font>
                </Label>
                <ChoiceBox fx:id="cbProducto" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="0" GridPane.rowIndex="7" />


                <Label style="-fx-font-weight:bold;" text="Cantidad solicitada" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>
                <TextField fx:id="txtCantidad" prefWidth="270" style="-fx-background-color:white; -fx-text-fill:black; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="1" />


                <Label style="-fx-font-weight:bold;" text="Fecha de solicitud" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>
                <DatePicker fx:id="dpFechaSolicitud" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight:bold;" text="Fecha estimada producción" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font><Font size="14" /></font>
                </Label>
                <DatePicker fx:id="dpFechaProduccion" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label style="-fx-font-weight:bold;" text="Prioridad" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <font><Font size="14" /></font>
                </Label>
                <ChoiceBox fx:id="cbPrioridad" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <Label style="-fx-font-weight:bold;" text="Responsable" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <font><Font size="14" /></font>
                </Label>
                <ChoiceBox fx:id="cbResponsable" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                <Label style="-fx-font-weight:bold;" text="Observaciones" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <font><Font size="14" /></font>
                </Label>
                <TextArea fx:id="txtObservaciones" prefHeight="60" prefWidth="270" style="-fx-background-color:white; -fx-border-color:purple;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <columnConstraints>
                    <ColumnConstraints minWidth="100" />
                    <ColumnConstraints />
                    <ColumnConstraints />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
               <RowConstraints />
               <RowConstraints />
                </rowConstraints>

            </GridPane>
            <HBox alignment="BOTTOM_CENTER" mouseTransparent="false" spacing="30">

                <StackPane.margin>
                    <Insets bottom="35" />
                </StackPane.margin>

                <Button onAction="#guardar" prefWidth="118" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Guardar">
                    <font><Font size="14" /></font>
                </Button>

                <Button onAction="#limpiar" prefWidth="117" style="-fx-background-color:#6d3c87; -fx-text-fill:white; -fx-font-weight:bold; -fx-background-radius:12;" text="Limpiar">
                    <font><Font size="14" /></font>
                </Button>

            </HBox>

        </StackPane>
    </center>

</BorderPane>
