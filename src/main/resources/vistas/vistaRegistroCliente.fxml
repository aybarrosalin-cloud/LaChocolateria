<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="533.0" prefWidth="949.0" style="-fx-background-color: #F8F5F0;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.chocolateria.controller.registrarclienteController">

    <center>
        <HBox alignment="CENTER" fillHeight="true" maxHeight="482.0" maxWidth="880.0"
              prefHeight="482.0" prefWidth="880.0" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 8);">

            <BorderPane.margin>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </BorderPane.margin>

            <VBox alignment="CENTER" maxWidth="440.0" minWidth="440.0" prefWidth="440.0" spacing="12.0">
                <padding>
                    <Insets bottom="26.0" left="40.0" right="40.0" top="10.0" />
                </padding>

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="REGISTRO DE NUEVO CLIENTE">
                        <font><Font size="24.0" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #666666;" text="Ingresa la información del cliente debajo."/>
                </VBox>

                <VBox spacing="8" style="-fx-background-color: #D1C4E9; -fx-padding: 20; -fx-background-radius: 30;">
                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="ID Cliente" />
                        <TextField fx:id="txtIdCliente" editable="false" />
                    </VBox>
                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Nombre" />
                        <TextField fx:id="txtNombre"/>
                    </VBox>

                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Apellido" />
                        <TextField fx:id="txtApellido"/>
                    </VBox>

                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Cédula" />
                        <TextField fx:id="txtCedula"/>
                    </VBox>

                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Correo electrónico" />
                        <TextField fx:id="txtEmail"/>
                    </VBox>

                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Teléfono" />
                        <TextField fx:id="txtTelefono"/>
                    </VBox>

                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #48295a;" text="Dirección" />
                        <TextField fx:id="txtDireccion"/>
                    </VBox>

                </VBox>

                <Button text="Registrarse"
                        onAction="#guardarCliente"
                        maxWidth="Infinity"
                        prefHeight="45.0"
                        style="-fx-background-color: #48295a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15;">
                    <font><Font size="14.0" /></font>
                </Button>

            </VBox>

            <StackPane maxWidth="454.0" minWidth="290.0" prefHeight="501.0" prefWidth="454.0"
                       style="-fx-background-color: #D1C4E9; -fx-background-radius: 0 30 30 0;">
                <children>
                    <ImageView fitHeight="513.0" fitWidth="966.0" preserveRatio="true">
                        <image>
                            <Image url="@../com/example/chocolateria/logo.png" />
                        </image>
                    </ImageView>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>