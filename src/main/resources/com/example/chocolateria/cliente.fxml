<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="533.0" prefWidth="949.0" style="-fx-background-color: #F9F7FC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chocolateria.ClienteController">

    <center>
        <HBox alignment="CENTER" maxHeight="480.0" maxWidth="880.0" style="-fx-background-color: white;                      -fx-background-radius: 30;                      -fx-effect: dropshadow(three-pass-box, rgba(74,44,111,0.25), 18, 0, 0, 8);">

            <BorderPane.margin> njjrnkosainayba5r
                <Insets bottom="20" left="20" right="20" top="20" />
            </BorderPane.margin>


            <VBox alignment="CENTER" prefWidth="665" spacing="14">
                <padding>
                    <Insets left="40" right="40" />
                </padding>


                <VBox spacing="6">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #4A2C6F;" text="REGISTRO DE CLIENTE">
                        <font><Font size="20" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #6B6B6B;" text="Por favor, ingresa tu información debajo" />
                </VBox>


                <VBox spacing="10" style="-fx-background-color: #E6DDF5;                              -fx-padding: 22;                              -fx-background-radius: 25;">

                    <VBox spacing="3">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A2C6F;" text="Nombre" />
                        <TextField fx:id="txtNombre" prefHeight="34" style="-fx-background-radius: 10;                                           -fx-border-radius: 10;                                           -fx-border-color: #C7B6E2;" />
                    </VBox>

                    <VBox spacing="3">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A2C6F;" text="Apellido" />
                        <TextField fx:id="txtApellido" prefHeight="34" style="-fx-background-radius: 10;                                           -fx-border-radius: 10;                                           -fx-border-color: #C7B6E2;" />
                    </VBox>

                    <VBox spacing="3">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A2C6F;" text="Email" />
                        <TextField fx:id="txtEmail" prefHeight="34" style="-fx-background-radius: 10;                                           -fx-border-radius: 10;                                           -fx-border-color: #C7B6E2;" />
                    </VBox>

                    <VBox spacing="3">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #4A2C6F;" text="Teléfono" />
                        <TextField fx:id="txtTelefono" prefHeight="34" style="-fx-background-radius: 10;                                           -fx-border-radius: 10;                                           -fx-border-color: #C7B6E2;" />
                    </VBox>

                </VBox>

                <Button maxWidth="Infinity" onAction="#registrarCliente" prefHeight="46" style="-fx-background-color: #4A2C6F;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 16;" text="Registrar Cliente">
                    <font><Font size="14" /></font>
                </Button>
                <TableView fx:id="tablaClientes" prefHeight="91.0" prefWidth="386.0">
                    <columns>
                        <TableColumn fx:id="colNombre" prefWidth="190.40001678466797" text="Nombre" />
                        <TableColumn fx:id="colApellido" prefWidth="198.39999389648438" text="Apellido" />
                        <TableColumn fx:id="colEmail" prefWidth="113.19998168945312" text="Email" />
                        <TableColumn fx:id="colTelefono" prefWidth="120" text="Teléfono" />
                    </columns>
                </TableView>
            </VBox>


            <StackPane prefWidth="440" style="-fx-background-color: #C7B6E2;                               -fx-background-radius: 0 30 30 0;">
                <ImageView fitHeight="351.0" fitWidth="414.0" preserveRatio="true">
                    <image>
                        <Image url="@logo.png" />
                    </image>
                </ImageView>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
