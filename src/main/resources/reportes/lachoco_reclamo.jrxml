<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Reclamo_LaChoco" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15"
              whenNoDataType="AllSectionsNoDetail"
              uuid="20000000-0000-0000-0000-000000000000">

    <style name="Default" forecolor="#212121" fontName="Arial" fontSize="9"/>

    <parameter name="ID_RECLAMO" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
    </parameter>
    <parameter name="LOGO" class="java.io.InputStream"/>

    <queryString language="SQL"><![CDATA[
        SELECT
            ISNULL(r.id_reclamo, $P{ID_RECLAMO})                     AS id_reclamo,
            ISNULL(r.id_cliente, 0)                                   AS id_cliente,
            ISNULL(r.cliente, '-- Sin dato --')                       AS cliente,
            ISNULL(r.id_orden, 0)                                     AS id_orden,
            ISNULL(r.tipo_reclamo, '-- Sin especificar --')           AS tipo_reclamo,
            ISNULL(r.estado, 'Abierto')                               AS estado,
            ISNULL(r.prioridad, 'Media')                              AS prioridad,
            ISNULL(r.descripcion, '-- Sin descripcion --')            AS descripcion,
            r.fecha_reclamo,
            ISNULL(r.id_empleado, 0)                                  AS id_empleado,
            ISNULL(e.nombre + ' ' + e.apellido, '-- No asignado --')  AS nombre_empleado,
            ISNULL(e.rol, 'Supervisor')                               AS cargo_empleado
        FROM (SELECT $P{ID_RECLAMO} AS id_reclamo) src
        LEFT JOIN tbl_reclamo   r ON r.id_reclamo  = src.id_reclamo
        LEFT JOIN tbl_empleado  e ON e.id_empleado = r.id_empleado
    ]]></queryString>

    <field name="id_reclamo"      class="java.lang.Integer"/>
    <field name="id_cliente"      class="java.lang.Integer"/>
    <field name="cliente"         class="java.lang.String"/>
    <field name="id_orden"        class="java.lang.Integer"/>
    <field name="tipo_reclamo"    class="java.lang.String"/>
    <field name="estado"          class="java.lang.String"/>
    <field name="prioridad"       class="java.lang.String"/>
    <field name="descripcion"     class="java.lang.String"/>
    <field name="fecha_reclamo"   class="java.sql.Date"/>
    <field name="id_empleado"     class="java.lang.Integer"/>
    <field name="nombre_empleado" class="java.lang.String"/>
    <field name="cargo_empleado"  class="java.lang.String"/>

    <background/>

