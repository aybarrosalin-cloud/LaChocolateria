<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Factura_LaChoco" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15"
              whenNoDataType="AllSectionsNoDetail"
              uuid="b1c2d3e4-f5a6-7890-bcde-f01234567890">

    <style name="Default" forecolor="#212121" fontName="Arial" fontSize="9"/>

    <style name="AltRow" mode="Transparent">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></conditionExpression>
            <style mode="Opaque" backcolor="#F5EEF8"/>
        </conditionalStyle>
    </style>

    <parameter name="ID_VENTA" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
    </parameter>
    <parameter name="LOGO" class="java.io.InputStream"/>

    <queryString language="SQL"><![CDATA[
        SELECT
            ISNULL(oc.id_orden, 0)                                              AS id_factura,
            ISNULL(CAST(oc.id_orden AS VARCHAR(20)), 'S/D')                     AS numero_factura,
            oc.fecha_registro                                                   AS fecha_factura,
            ISNULL(c.cedula, '')                                                AS rnc_cliente,
            ISNULL(od.producto, '-- Sin detalle --')                            AS producto,
            ISNULL(od.cantidad, 0)                                              AS cantidad,
            CAST(ISNULL(od.precio, 0) AS DECIMAL(10,2))                         AS precio_unitario,
            CAST(ISNULL(od.cantidad,0) * ISNULL(od.precio,0) AS DECIMAL(10,2))        AS subtotal_linea,
            CAST(ISNULL(od.cantidad,0) * ISNULL(od.precio,0) * 0.18 AS DECIMAL(10,2)) AS itbis_linea,
            CAST(ISNULL(od.cantidad,0) * ISNULL(od.precio,0) * 1.18 AS DECIMAL(10,2)) AS total_linea,
            ISNULL(oc.metodo_pago, '')                                          AS tipo_pago,
            ISNULL(oc.estado, '')                                               AS estado_pago,
            CAST(0 AS DECIMAL(10,2))                                            AS descuento,
            CAST(0 AS DECIMAL(10,2))                                            AS monto_pagado,
            CAST(0 AS DECIMAL(10,2))                                            AS balance_pendiente,
            ISNULL(oc.cliente, 'Consumidor Final')                              AS nombre_cliente,
            ISNULL(c.cedula, '')                                                AS cedula_cliente,
            ISNULL(c.telefono, '')                                              AS tel_cliente,
            ISNULL(c.email, '')                                                 AS email_cliente,
            ISNULL(c.direccion, '')                                             AS dir_cliente,
            ISNULL(oc.cajero, '')                                                AS cajero
        FROM (SELECT $P{ID_VENTA} AS id_orden) src
        LEFT JOIN tbl_orden_cliente  oc ON oc.id_orden   = src.id_orden
        LEFT JOIN tbl_orden_detalle  od ON od.id_orden   = oc.id_orden
        LEFT JOIN tbl_cliente         c ON  c.id_cliente = oc.id_cliente
        ORDER BY od.id_detalle
    ]]></queryString>

    <field name="id_factura"       class="java.lang.Integer"/>
    <field name="numero_factura"   class="java.lang.String"/>
    <field name="fecha_factura"    class="java.sql.Timestamp"/>
    <field name="rnc_cliente"      class="java.lang.String"/>
    <field name="producto"         class="java.lang.String"/>
    <field name="cantidad"         class="java.lang.Integer"/>
    <field name="precio_unitario"  class="java.math.BigDecimal"/>
    <field name="subtotal_linea"   class="java.math.BigDecimal"/>
    <field name="itbis_linea"      class="java.math.BigDecimal"/>
    <field name="total_linea"      class="java.math.BigDecimal"/>
    <field name="tipo_pago"        class="java.lang.String"/>
    <field name="estado_pago"      class="java.lang.String"/>
    <field name="descuento"        class="java.math.BigDecimal"/>
    <field name="monto_pagado"     class="java.math.BigDecimal"/>
    <field name="balance_pendiente" class="java.math.BigDecimal"/>
    <field name="nombre_cliente"   class="java.lang.String"/>
    <field name="cedula_cliente"   class="java.lang.String"/>
    <field name="tel_cliente"      class="java.lang.String"/>
    <field name="email_cliente"    class="java.lang.String"/>
    <field name="dir_cliente"      class="java.lang.String"/>
    <field name="cajero"           class="java.lang.String"/>

    <variable name="V_SUBTOTAL" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{subtotal_linea}]]></variableExpression>
    </variable>
    <variable name="V_ITBIS" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{itbis_linea}]]></variableExpression>
    </variable>
    <variable name="V_DESCUENTO" class="java.math.BigDecimal" calculation="First">
        <variableExpression><![CDATA[$F{descuento}]]></variableExpression>
    </variable>
    <variable name="V_TOTAL" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{total_linea}]]></variableExpression>
    </variable>

