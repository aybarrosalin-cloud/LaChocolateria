	<parameter name="ID_VENTA" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="LOGO" class="java.io.InputStream"/>
	<queryString><![CDATA[
        SELECT
            ISNULL(v.id_venta, 0)                                         AS id_factura,
            ISNULL(CAST(v.id_venta AS VARCHAR(20)), 'S/D')                AS numero_factura,
            v.fecha_venta                                                 AS fecha_factura,
            ISNULL(c.cedula, '')                                          AS rnc_cliente,
            ISNULL(od.producto, '-- Sin detalle --')                      AS producto,
            ISNULL(od.cantidad, 0)                                        AS cantidad,
            ISNULL(od.precio, 0)                                          AS precio_unitario,
            ISNULL(od.cantidad, 0) * ISNULL(od.precio, 0)                AS subtotal_linea,
            CAST(0 AS DECIMAL(10,2))                                      AS itbis_linea,
            ISNULL(od.cantidad, 0) * ISNULL(od.precio, 0)                AS total_linea,
            ISNULL(v.subtotal, 0)                                         AS subtotal_venta,
            ISNULL(v.itbis, 0)                                            AS itbis_venta,
            ISNULL(v.monto_total, 0)                                      AS monto_total,
            ISNULL(v.descuento, 0)                                        AS descuento,
            ISNULL(v.tipo_pago, '')                                       AS tipo_pago,
            ISNULL(v.estado_pago, '')                                     AS estado_pago,
            ISNULL(v.monto_pagado, 0)                                     AS monto_pagado,
            ISNULL(v.balance_pendiente, 0)                                AS balance_pendiente,
            ISNULL(CAST(v.id_comprobante AS VARCHAR(20)), '')             AS ncf,
            ''                                                            AS tipo_comprobante,
            ISNULL(e.nombre + ' ' + e.apellido, '')                      AS cajero,
            ISNULL(c.nombre + ' ' + c.apellido, 'Consumidor Final')      AS nombre_cliente,
            ISNULL(c.cedula, '')                                          AS cedula_cliente,
            ISNULL(c.telefono, '')                                        AS tel_cliente,
            ISNULL(c.email, '')                                           AS email_cliente,
            ISNULL(c.direccion, '')                                       AS dir_cliente
        FROM (SELECT $P{ID_VENTA} AS id_venta) src
        LEFT JOIN tbl_venta             v  ON  v.id_venta      = src.id_venta
        LEFT JOIN tbl_empleado           e  ON  e.id_empleado   = v.id_empleado
        LEFT JOIN tbl_orden_cliente      oc ON oc.id_orden      = v.id_orden
        LEFT JOIN tbl_orden_detalle      od ON od.id_orden      = oc.id_orden
        LEFT JOIN tbl_cliente            c  ON  c.id_cliente    = oc.id_cliente
        ORDER BY od.id_detalle
    ]]></queryString>
