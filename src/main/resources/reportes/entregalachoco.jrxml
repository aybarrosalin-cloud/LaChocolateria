<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Delivery_LaChoco" language="java"
              pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15"
              whenNoDataType="AllSectionsNoDetail"
              uuid="40000000-0000-0000-0000-000000000000">

    <style name="Default" forecolor="#212121" fontName="Arial" fontSize="9"/>

    <parameter name="ID_ENVIO" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
    </parameter>
    <parameter name="LOGO" class="java.io.InputStream"/>

    <queryString language="SQL"><![CDATA[
        SELECT
            ISNULL(oc.id_orden, 0)                                        AS id_orden,
            oc.fecha_registro,
            oc.fecha_entrega,
            ISNULL(oc.metodo_pago, '')                                    AS metodo_pago,
            ISNULL(oc.estado, '')                                         AS estado_orden,
            ISNULL(oc.observaciones, '')                                  AS observaciones,
            ISNULL(c.nombre + ' ' + c.apellido, ISNULL(e.cliente, '-- Sin cliente --')) AS nombre_cliente,
            ISNULL(c.cedula, '')                                          AS cedula_cliente,
            ISNULL(c.telefono, '')                                        AS tel_cliente,
            ISNULL(c.email, '')                                           AS email_cliente,
            ISNULL(c.direccion, '')                                       AS dir_cliente,
            ISNULL(od.codigo, '')                                         AS codigo,
            ISNULL(od.producto, '-- Sin productos en orden --')           AS producto,
            ISNULL(od.categoria, '')                                      AS categoria,
            ISNULL(od.cantidad, 0)                                        AS cantidad,
            ISNULL(od.precio, 0)                                          AS precio,
            ISNULL(od.cantidad, 0) * ISNULL(od.precio, 0)                AS subtotal,
            ISNULL(e.numero_guia, '-- Sin guia --')                       AS numero_guia,
            ISNULL(e.transportista, '-- Sin transportista --')            AS transportista,
            ISNULL(e.provincia, '')                                       AS provincia,
            ISNULL(e.ciudad, '')                                          AS ciudad,
            ISNULL(e.direccion, ISNULL(c.direccion, ''))                  AS dir_envio,
            e.fecha_envio,
            e.fecha_entrega                                               AS fecha_entrega_real,
            ISNULL(e.estado, '')                                          AS estado_envio,
            ISNULL(e.temperatura_transporte, '')                          AS temperatura
        FROM (SELECT $P{ID_ENVIO} AS id_envio) src
        LEFT JOIN tbl_envio e ON e.id_envio = src.id_envio
        LEFT JOIN tbl_cliente c ON c.id_cliente = e.id_cliente
        OUTER APPLY (
            SELECT TOP 1 *
            FROM tbl_orden_cliente
            WHERE id_cliente = e.id_cliente
            ORDER BY fecha_registro DESC
        ) oc
        LEFT JOIN tbl_orden_detalle od ON od.id_orden = oc.id_orden
        ORDER BY od.id_detalle
    ]]></queryString>

    <field name="id_orden"          class="java.lang.Integer"/>
    <field name="fecha_registro"    class="java.sql.Date"/>
    <field name="fecha_entrega"     class="java.sql.Date"/>
    <field name="metodo_pago"       class="java.lang.String"/>
    <field name="estado_orden"      class="java.lang.String"/>
    <field name="observaciones"     class="java.lang.String"/>
    <field name="nombre_cliente"    class="java.lang.String"/>
    <field name="cedula_cliente"    class="java.lang.String"/>
    <field name="tel_cliente"       class="java.lang.String"/>
    <field name="email_cliente"     class="java.lang.String"/>
    <field name="dir_cliente"       class="java.lang.String"/>
    <field name="codigo"            class="java.lang.String"/>
    <field name="producto"          class="java.lang.String"/>
    <field name="categoria"         class="java.lang.String"/>
    <field name="cantidad"          class="java.lang.Integer"/>
    <field name="precio"            class="java.math.BigDecimal"/>
    <field name="subtotal"          class="java.math.BigDecimal"/>
    <field name="numero_guia"       class="java.lang.String"/>
    <field name="transportista"     class="java.lang.String"/>
    <field name="provincia"         class="java.lang.String"/>
    <field name="ciudad"            class="java.lang.String"/>
    <field name="dir_envio"         class="java.lang.String"/>
    <field name="fecha_envio"       class="java.sql.Date"/>
    <field name="fecha_entrega_real" class="java.sql.Date"/>
    <field name="estado_envio"      class="java.lang.String"/>
    <field name="temperatura"       class="java.lang.String"/>

    <variable name="V_TOTAL" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
    </variable>
    <variable name="V_ITEMS" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{cantidad}]]></variableExpression>
    </variable>

    <background/>

