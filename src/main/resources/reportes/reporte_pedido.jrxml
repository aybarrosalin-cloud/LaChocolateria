	<style name="EmpresaNombre" forecolor="#FFFFFF" fontName="Arial" fontSize="22.0" isBold="true"/>
	<style name="CampoLabel" forecolor="#C8A8E9" fontName="Arial" fontSize="8.0" isBold="true"/>
	<style name="FooterStyle" forecolor="#AAAAAA" fontName="Arial" fontSize="7.5"/>
