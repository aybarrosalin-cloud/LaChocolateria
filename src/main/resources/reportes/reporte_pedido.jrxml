	<style name="DetalleTxt" forecolor="#333333" fontName="Arial" fontSize="9.0"/>
	<parameter name="ID_PEDIDO" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[128]]></defaultValueExpression>
	</parameter>
	<parameter name="LOGO" class="java.io.InputStream"/>
	<queryString><![CDATA[
		SELECT
			ISNULL(p.id_pedido, $P{ID_PEDIDO})                            AS id_pedido,
			ISNULL(p.cantidad, 0)                                         AS cantidad,
			ISNULL(p.descripcion, '-- Sin descripci&oacute;n --')         AS descripcion,
			ISNULL(p.id_cliente, 0)                                       AS id_cliente,
			ISNULL(p.id_venta, 0)                                         AS id_venta,
			p.fecha_pedido,
			ISNULL(c.nombre + ' ' + c.apellido, 'Consumidor Final')       AS nombre_cliente,
			ISNULL(c.cedula, '&mdash;')                                   AS cedula_cliente,
			ISNULL(c.telefono, '&mdash;')                                 AS tel_cliente,
			ISNULL(c.direccion, '&mdash;')                                AS dir_cliente,
			ISNULL(e.nombre + ' ' + e.apellido, '&mdash;')                AS nombre_empleado,
			ISNULL(e.rol, '&mdash;')                                      AS rol_empleado
		FROM (SELECT $P{ID_PEDIDO} AS id_pedido) src
		LEFT JOIN tbl_pedido  p ON p.id_pedido = src.id_pedido
		LEFT JOIN tbl_cliente c ON c.id_cliente = p.id_cliente
		LEFT JOIN tbl_venta   v ON v.id_venta    = p.id_venta
		LEFT JOIN tbl_empleado e ON e.id_empleado = v.id_empleado
	]]></queryString>
	<field name="id_pedido" class="java.lang.Integer"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="id_cliente" class="java.lang.Integer"/>
	<field name="id_venta" class="java.lang.Integer"/>
	<field name="fecha_pedido" class="java.sql.Timestamp"/>
	<field name="nombre_cliente" class="java.lang.String"/>
	<field name="cedula_cliente" class="java.lang.String"/>
	<field name="tel_cliente" class="java.lang.String"/>
	<field name="dir_cliente" class="java.lang.String"/>
	<field name="nombre_empleado" class="java.lang.String"/>
	<field name="rol_empleado" class="java.lang.String"/>
