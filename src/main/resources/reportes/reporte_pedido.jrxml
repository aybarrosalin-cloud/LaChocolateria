<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Pedido_LaChoco" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15"
              whenNoDataType="AllSectionsNoDetail"
              uuid="30000000-0000-0000-0000-000000000000">

    <style name="Default" forecolor="#212121" fontName="Arial" fontSize="9"/>

    <parameter name="ID_PEDIDO" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
    </parameter>
    <parameter name="LOGO" class="java.io.InputStream"/>

    <queryString language="SQL"><![CDATA[
        SELECT
            ISNULL(oc.id_orden, $P{ID_PEDIDO})                          AS id_pedido,
            ISNULL(oc.id_cliente, 0)                                     AS id_cliente,
            ISNULL(oc.id_orden, 0)                                       AS id_venta,
            oc.fecha_registro                                            AS fecha_pedido,
            ISNULL(oc.cliente, 'Consumidor Final')                       AS nombre_cliente,
            ISNULL(c.cedula, '')                                         AS cedula_cliente,
            ISNULL(c.telefono, '')                                       AS tel_cliente,
            ISNULL(c.direccion, '')                                      AS dir_cliente,
            ISNULL(od.producto, '-- Sin detalle --')                     AS descripcion,
            ISNULL(od.cantidad, 0)                                       AS cantidad,
            ISNULL(oc.cajero, '')                                        AS nombre_empleado,
            ISNULL(oc.metodo_pago, '')                                   AS rol_empleado
        FROM (SELECT $P{ID_PEDIDO} AS id_orden) src
        LEFT JOIN tbl_orden_cliente oc ON oc.id_orden = src.id_orden
        LEFT JOIN tbl_orden_detalle od ON od.id_orden = oc.id_orden
        LEFT JOIN tbl_cliente        c ON  c.id_cliente = oc.id_cliente
        ORDER BY od.id_detalle
    ]]></queryString>

    <field name="id_pedido"       class="java.lang.Integer"/>
    <field name="id_cliente"      class="java.lang.Integer"/>
    <field name="id_venta"        class="java.lang.Integer"/>
    <field name="fecha_pedido"    class="java.sql.Timestamp"/>
    <field name="nombre_cliente"  class="java.lang.String"/>
    <field name="cedula_cliente"  class="java.lang.String"/>
    <field name="tel_cliente"     class="java.lang.String"/>
    <field name="dir_cliente"     class="java.lang.String"/>
    <field name="descripcion"     class="java.lang.String"/>
    <field name="cantidad"        class="java.lang.Integer"/>
    <field name="nombre_empleado" class="java.lang.String"/>
    <field name="rol_empleado"    class="java.lang.String"/>

    <variable name="V_TOTAL_CANT" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{cantidad}]]></variableExpression>
    </variable>

    <background/>

